# ============================================================
# cab-spark-data-pipeline — local development environment
# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.
# ============================================================

# ── Postgres (bronze + silver) ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cab_pipeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Airflow metadata database ────────────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# ── Airflow webserver ────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=changeme

# Generate a Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Delta Lake (gold) ────────────────────────────────────────
# For local development use a local path; for production use S3.
DELTA_GOLD_BASE_PATH=/data/gold
DELTA_CHECKPOINT_PATH=/data/checkpoints

# For S3:
# DELTA_GOLD_BASE_PATH=s3://your-bucket/gold
# DELTA_CHECKPOINT_PATH=s3://your-bucket/checkpoints
# AWS_REGION=us-east-1

# ── Spark ────────────────────────────────────────────────────
SPARK_APP_NAME=cab-spark-data-pipeline
SPARK_MASTER=local[*]
SPARK_EXECUTOR_MEMORY=4g
SPARK_DRIVER_MEMORY=2g
SPARK_JDBC_NUM_PARTITIONS=8
SPARK_JDBC_FETCH_SIZE=50000

# ── Airflow REST API (CLI) ───────────────────────────────────
AIRFLOW_API_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# ── Superset (optional) ──────────────────────────────────────
SUPERSET_SECRET_KEY=changeme

# ---------------------------------------------------------------------------
# Java / PySpark — docker/Dockerfile.airflow
# ---------------------------------------------------------------------------
# JAVA_HOME is hardcoded in docker/Dockerfile.airflow for Apple Silicon (arm64).
# If you are on an Intel machine or Linux x86_64, change line 21 before building:
#
#   arm64 (Apple Silicon — default):
#     ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-arm64
#
#   amd64 (Intel Mac / Linux x86_64):
#     ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
#
# Check your arch:  uname -m
#   arm64  → use arm64 path (no change needed)
#   x86_64 → use amd64 path
